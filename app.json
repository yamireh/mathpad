{
  "expo": {
    "name": "MathPen",
    "slug": "mathpad",
    "scheme": "mathpad",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F7FB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mc.mathpad",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mc.mathpad",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5B74E8"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.5"
          }
        }
      ],
      "expo-font",
      "expo-asset",
      "expo-audio",
      "expo-iap"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "80bb5400-6728-42e4-9ecd-7715a5b94333"
      }
    },
    "owner": "yamireh"
  }
}
